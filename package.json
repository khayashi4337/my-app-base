  "private": true,
  "description": "Description for my_app_base",
  "license": "UNLICENSED",
  "scripts": {
    "cleanup": "rimraf build/resources/main/static/",
    "jest": "jest --coverage --logHeapUsage --maxWorkers=2 --config src/test/javascript/jest.conf.js",
    "jest:update": "npm run jest -- --updateSnapshot",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "prettier:format": "prettier --write \"{,src/**/}*.{md,json,ts,tsx,css,scss,yml}\"",
    "start": "npm run webpack:dev",
    "start-tls": "npm run webpack:dev -- --env tls=true",
    "test": "npm run lint && npm run jest",
    "test-ci": "npm run lint && npm run jest:update",
    "test:watch": "npm test -- --watch",
    "webpack": "webpack",
    "webpack:build": "npm run cleanup && npm run webpack:build:main",
    "webpack:build:main": "npm run webpack -- --config webpack/webpack.dev.js --env stats=minimal",
    "webpack:dev": "webpack serve --config webpack/webpack.dev.js --port=9060 --env stats=minimal",
    "webpack:dev-verbose": "webpack serve --config webpack/webpack.dev.js --port=9060 --progress --env stats=normal",
    "webpack:prod": "npm run cleanup && npm run webpack:prod:main",
    "webpack:prod:main": "npm run webpack -- --config webpack/webpack.prod.js --progress",
    "webpack:test": "npm run test"
  },
